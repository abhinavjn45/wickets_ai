generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model playerprofile {
  id           String    @id @default(uuid())
  userId       String    @unique(map: "PlayerProfile_userId_key")
  fullName     String
  city         String
  gender       String
  avatarUrl    String?
  battingStyle String?
  bowlingStyle String?
  playingRole  String?
  dateOfBirth  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         user      @relation(fields: [userId], references: [id], onDelete: Cascade, map: "PlayerProfile_userId_fkey")
}

model user {
  id            String         @id @default(uuid())
  firebaseUid   String?        @unique(map: "User_firebaseUid_key")
  email         String?        @unique(map: "User_email_key")
  phone         String?        @unique(map: "User_phone_key")
  role          user_role      @default(PLAYER)
  onboarded     Boolean        @default(false)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  username      String?        @unique(map: "User_username_key")
  playerprofile playerprofile?
  requirements  requirement[]
}

model requirement {
  id        String   @id @default(uuid())
  userId    String
  type      String   // TOURNAMENT, PLAYER, TEAM, MATCH, GROUND, UMPIRE, SCORER, COMMENTATOR, STREAMER
  category  String   // The 10 grid items: teams_tourney, join_tourney, etc.
  title     String
  city      String
  area      String
  ground    String?
  details   String?  @db.Text
  metaData  Json?    // For specific fields like overs, ballType, prizeType, etc.
  status    String   @default("OPEN") // OPEN, CLOSED, EXPIRED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([city])
  @@index([category])
}

enum user_role {
  PLAYER
  UMPIRE
  SCORER
  OFFICIAL
  ADMIN
}
